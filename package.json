{
  "name": "scrub-exif",
  "version": "0.1.0",
  "description": "Losslessly strip Exif/GPS/XMP/IPTC metadata from JPEG and PNG. Zero dependencies, no native binaries, runs anywhere.",
  "keywords": [
    "exif",
    "gps",
    "metadata",
    "privacy",
    "jpeg",
    "png",
    "lossless",
    "strip",
    "scrub",
    "xmp",
    "iptc"
  ],
  "license": "MIT",
  "author": "kkhys",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkhys/scrub-exif.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "scrub-exif": "./dist/cli.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
